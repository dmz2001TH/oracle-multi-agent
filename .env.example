# oracle-multi-agent/.env
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════
# LLM Provider
# ═══════════════════════════════════════════
LLM_PROVIDER=promptdee
# Options: 'gemini', 'promptdee', 'openai'

# Google Gemini (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-api-key-here
AGENT_MODEL=gemini-2.0-flash

# OpenAI-compatible (optional, for custom endpoints)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ═══════════════════════════════════════════
# Hub Server
# ═══════════════════════════════════════════
HUB_PORT=3456
HUB_HOST=0.0.0.0

# ═══════════════════════════════════════════
# Database & Storage
# ═══════════════════════════════════════════
DB_PATH=./data/oracle.db
VAULT_PATH=./ψ

# Oracle Memory System
ORACLE_DATA_DIR=~/.config/oracle
ORACLE_DB_PATH=./data/oracle.db

# ═══════════════════════════════════════════
# Agents
# ═══════════════════════════════════════════
MAX_CONCURRENT_AGENTS=5

# ═══════════════════════════════════════════
# Federation (multi-machine, optional)
# ═══════════════════════════════════════════
NODE_NAME=local
FEDERATION_TOKEN=
# Add peers via API: POST /api/federation/peers
# Or in maw.config.json

# ═══════════════════════════════════════════
# Transport
# ═══════════════════════════════════════════
# Transport order: local → ws → http
# Picked automatically based on target

# ═══════════════════════════════════════════
# Plugins (optional)
# ═══════════════════════════════════════════
# Place .js plugin files in ./plugins/
# They auto-load on startup

# ═══════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════
LOG_LEVEL=info
