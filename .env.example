# oracle-multi-agent/.env
# Copy this to .env and fill in your values

# LLM Provider: 'gemini' or 'promptdee'
LLM_PROVIDER=promptdee

# Google Gemini API Key (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-api-key-here

# Hub server
HUB_PORT=3456
HUB_HOST=0.0.0.0

# Database
DB_PATH=./data/oracle.db

# Agents
MAX_CONCURRENT_AGENTS=5
AGENT_MODEL=gemini-2.0-flash

# Federation (for multi-machine, optional)
FEDERATION_TOKEN=
NODE_NAME=local

# Logging
LOG_LEVEL=info
