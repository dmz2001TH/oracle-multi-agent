{
  "name": "oracle-multi-agent",
  "version": "3.0.0",
  "description": "🧠 ARRA Office — Oracle Multi-Agent System with memory, chat, and team orchestration",
  "bin": {
    "oracle": "./bin/oracle"
  },
  "main": "src/hub/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/hub/index.js",
    "setup": "node scripts/setup.js",
    "chat": "node bin/oracle chat",
    "status": "node bin/oracle status",
    "team": "node bin/oracle team",
    "recap": "node bin/oracle recap",
    "rrr": "node bin/oracle rrr",
    "standup": "node bin/oracle standup",
    "daemon": "pm2 start ecosystem.config.cjs",
    "daemon:stop": "pm2 stop oracle-hub",
    "daemon:logs": "pm2 logs oracle-hub"
  },
  "keywords": ["ai", "multi-agent", "gemini", "llm", "agents", "memory", "sqlite", "oracle"],
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
