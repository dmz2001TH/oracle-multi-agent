{
  "name": "oracle-multi-agent",
  "version": "5.0.0",
  "description": "🧠 ARRA Office — Oracle Multi-Agent System with memory, federation, transport, plugins, and team orchestration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "oracle": "./bin/oracle"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dashboard:dev": "cd src/dashboard && npx vite",
    "dashboard:build": "cd src/dashboard && npx vite build",
    "migrate": "echo 'Migration placeholder - Oracle DB schema setup'",
    "start:service": "npx tsx services/start-service.ts",
    "start:dashboard": "npx tsx api/start-dashboard.ts",
    "start:all": "concurrently \"npm run start:service\" \"npm run start:dashboard\""
  },
  "keywords": [
    "ai",
    "multi-agent",
    "oracle",
    "federation",
    "transport",
    "plugins",
    "maw",
    "arra",
    "office",
    "team",
    "orchestration",
    "typescript"
  ],
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@xenova/transformers": "^2.17.2",
    "arg": "^5.0.2",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "execa": "^9.0.0",
    "express": "^5.2.1",
    "hono": "^4.12.5",
    "mqtt": "^5.15.1",
    "node-pty": "^1.0.0",
    "socket.io": "^4.8.3",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
