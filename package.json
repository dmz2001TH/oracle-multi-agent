{
  "name": "oracle-multi-agent",
  "version": "5.0.0",
  "description": "🧠 ARRA Office — Oracle Multi-Agent System with memory, federation, transport, plugins, and team orchestration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "oracle": "./bin/oracle"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dashboard:dev": "cd src/dashboard && npx vite",
    "dashboard:build": "cd src/dashboard && npx vite build"
  },
  "keywords": [
    "ai", "multi-agent", "oracle", "federation", "transport", "plugins",
    "maw", "arra", "office", "team", "orchestration", "typescript"
  ],
  "dependencies": {
    "hono": "^4.12.5",
    "@hono/node-server": "^1.13.0",
    "mqtt": "^5.15.1",
    "arg": "^5.0.2",
    "execa": "^9.0.0",
    "node-pty": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "ws": "^8.18.0",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
